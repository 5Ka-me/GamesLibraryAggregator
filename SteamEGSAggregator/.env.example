# Copy to .env and fill in real values. `docker compose` loads .env automatically.

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=steamegs
POSTGRES_PORT=5432

# --- Security (REQUIRED) ---
# AES-256 key, base64-encoded 32 bytes, used to encrypt secrets (Steam API key, EGS tokens) at rest.
# Generate one with:  openssl rand -base64 32
# Keep it stable — changing it makes already-encrypted secrets unreadable.
SECURITY_ENCRYPTION_KEY=

# --- Frontend / runtime ---
# Address the browser uses to reach the API (the published api port).
REACT_APP_API_URL=http://localhost:8080
ASPNETCORE_ENVIRONMENT=Production
